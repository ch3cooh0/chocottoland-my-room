{
  "compilerOptions": {
    "outDir": "./dist",
    "module": "commonjs",  // esnextからcommonjsに変更
    "target": "es6",
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "sourceMap": true,
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*"]
}
